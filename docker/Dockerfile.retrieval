FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    uvicorn[standard] \
    fastapi \
    pydantic \
    "langchain-core>=1.4.0" \
    "langchain-openai==1.2.2" \
    "langchain-qdrant==1.1.0"

COPY retrieval_server.py .

CMD ["uvicorn", "retrieval_server:app", "--host", "0.0.0.0", "--port", "8000"]
