# Configuration for testing/test_retrieval_server.py and testing/create_test_collection.py
#
# Copy this file to testing/.env and fill in your values.
# CLI flags always override these values.

# Retrieval server (test_retrieval_server.py only)
RETRIEVAL_SERVER_URL=http://localhost:8000

# Qdrant
QDRANT_URL=http://host.docker.internal:6333
QDRANT_COLLECTION=documents

# Embeddings — Ollama (default)
EMBEDDINGS_BASE_URL=http://localhost:11434/v1
EMBEDDINGS_API_KEY=ollama
EMBEDDINGS_MODEL=nomic-embed-text

# Embeddings — OpenAI (uncomment and fill in to use instead)
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# EMBEDDINGS_API_KEY=sk-...
# EMBEDDINGS_MODEL=text-embedding-3-small

# Embeddings — Nomic hosted (uncomment and fill in to use instead)
# EMBEDDINGS_BASE_URL=https://api-atlas.nomic.ai/v1
# EMBEDDINGS_API_KEY=nk-...
# EMBEDDINGS_MODEL=nomic-embed-text-v1.5

# Number of results to retrieve (test_retrieval_server.py only)
TOP_K=9
